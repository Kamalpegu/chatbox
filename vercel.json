{
  "version": 2,
  "builds": [
    {
      "src": "chatbox/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "chatbox/wsgi.py"
    }
  ],
  "build": {
    "env": {
      "DJANGO_SETTINGS_MODULE": "chatbox.settings"
    }
  },
  "buildCommand": "python manage.py migrate --noinput"
}
