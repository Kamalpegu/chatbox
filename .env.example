# Django Settings
SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend-domain.com

# Database (Postgres recommended for production)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis (required for production Channels)
REDIS_URL=redis://:password@host:6379

# CSRF and security
CSRF_TRUSTED_ORIGINS=https://your-vercel-domain.com,https://your-backend-domain.com

# Email (optional, for allauth)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
